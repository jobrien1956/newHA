  "content": "<div class=\"col-sm-12 blog-post\">\n\t\t\t\t\t\t<div class=\"col-sm-6\">\n\t\t\t\t\t\t\t<picture>\n\t\t\t\t\t\t\t\t<img class=\"img-responsive\" src=\"img/tourdivide/day33/maps.Par4040.gif\" alt=\"\" width=\"100%\">\n\t\t\t\t\t\t\t\t<span class=\"caption text-muted\">\n                                        <a href=\"http://www.blm.gov/nm/st/en/prog/NLCS/ELMA_NCA.html\">Map from BLM site </a>\n                                    </span>\n\t\t\t\t\t\t\t</picture>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"col-sm-6\">\n\t\t\t\t\t\t\t<picture>\n\t\t\t\t\t\t\t\t<img class=\"img-responsive\" src=\"img/tourdivide/day33/day33malpais_ge.png\" alt=\"\" width=\"100%\">\n\t\t\t\t\t\t\t\t<span class=\"caption text-muted\">This map from Google Earth shows the road with the lava on the west side.\n                                    </span>\n\t\t\t\t\t\t\t</picture>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<a href=\"#\">\n\t\t\t\t\t\t<img class=\"img-responsive\" src=\"elev/20150711summ.png\" alt=\"\" style=\"width:95%\">\n\t\t\t\t\t\t<a href=\"#\">\n\t\t\t\t\t\t\t<img class=\"img-responsive\" src=\"elev/20150711elev.png\" alt=\"\" style=\"width:95%\">\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</a>\n\t\t\t\t\t<h2 class=\"section-heading\">El Malpais - National Conservation Area</h2>\n\t\t\t\t\t<picture>\n\t\t\t\t\t\t<img class=\"img-responsive\" src=\"img/tourdivide/day33/day33pic07.JPG\" alt=\"\" width=\"95%\">\n\t\t\t\t\t\t<span class=\"caption text-muted\">Stone formations all around.\n                            </span>\n\t\t\t\t\t</picture>\n\n\t\t\t\t\t<picture>\n\t\t\t\t\t\t<img class=\"img-responsive\" src=\"img/tourdivide/day33/day33pic00.JPG\" alt=\"\" width=\"95%\">\n\t\t\t\t\t\t<span class=\"caption text-muted\">This was a mostly straight stretch which I stiched into 1 picture.\n                            </span>\n\t\t\t\t\t</picture>\n\t\t\t\t\t<div id=\"carousel1\" class=\"carousel slide\" data-ride=\"carousel\">\n\t\t\t\t\t\t<ol class=\"carousel-indicators\">\n\t\t\t\t\t\t\t<li data-target=\"#carousel1\" data-slide-to=\"0\"></li>\n\t\t\t\t\t\t\t<li data-target=\"#carousel1\" data-slide-to=\"1\"></li>\n\t\t\t\t\t\t\t<li data-target=\"#carousel1\" data-slide-to=\"2\"></li>\n\t\t\t\t\t\t</ol>\n\t\t\t\t\t\t<div class=\"carousel-inner\" role=\"listbox\">\n\t\t\t\t\t\t\t<div class=\"item active\"><img src=\"img/tourdivide/day33/day33pic02.JPG\" alt=\"First slide image\"\n\t\t\t\t\t\t\t                              class=\"center-block\">\n\t\t\t\t\t\t\t\t<div class=\"carousel-caption\">\n\t\t\t\t\t\t\t\t\t<h3>El Malpais</h3>\n\t\t\t\t\t\t\t\t\t<p>1</p>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"item\"><img src=\"img/tourdivide/day33/day33pic03.JPG\" alt=\"Second slide image\"\n\t\t\t\t\t\t\t                       class=\"center-block\">\n\t\t\t\t\t\t\t\t<div class=\"carousel-caption\">\n\t\t\t\t\t\t\t\t\t<h3>El Malpais</h3>\n\t\t\t\t\t\t\t\t\t<p>2</p>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t<div class=\"item\"><img src=\"img/tourdivide/day33/day33pic04.JPG\" alt=\"Third slide image\"\n\t\t\t\t\t\t\t                       class=\"center-block\">\n\t\t\t\t\t\t\t\t<div class=\"carousel-caption\">\n\t\t\t\t\t\t\t\t\t<h3>El Malpais</h3>\n\t\t\t\t\t\t\t\t\t<p>3</p>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<a class=\"left carousel-control\" href=\"#carousel1\" role=\"button\" data-slide=\"prev\">\n\t\t\t\t\t\t\t<span class=\"glyphicon glyphicon-chevron-left\" aria-hidden=\"true\"></span>\n\t\t\t\t\t\t\t<span class=\"sr-only\">Previous</span></a>\n\t\t\t\t\t\t<a class=\"right carousel-control\" href=\"#carousel1\" role=\"button\" data-slide=\"next\">\n                                        <span class=\"glyphicon glyphicon-chevron-right\" aria-hidden=\"true\">\n                                        </span><span class=\"sr-only\">Next</span>\n\t\t\t\t\t\t</a>\n\t\t\t\t\t</div>\n\t\t\t\t\t<h2 class=\"section-heading\">La Ventana Natural Arch</h2>\n\t\t\t\t\t<picture>\n\t\t\t\t\t\t<img class=\"img-responsive\" src=\"img/tourdivide/day33/day33pic05.JPG\" alt=\"\" width=\"95%\">\n\t\t\t\t\t\t<span class=\"caption text-muted\">From the pull out area\n                            </span>\n\t\t\t\t\t</picture>\n\n\t\t\t\t\t<picture>\n\t\t\t\t\t\t<img class=\"img-responsive\" src=\"img/tourdivide/day33/ELMA_NCA.gif\" alt=\"\" width=\"95%\">\n\t\t\t\t\t\t<span class=\"caption text-muted\">\n                                        <a href=\"http://www.blm.gov/nm/st/en/prog/NLCS/ELMA_NCA.html\">Picture from BLM site </a>\n                            </span>\n\t\t\t\t\t</picture>\n\t\t\t\t\t<p>\n\t\t\t\t\t\tStopped off at the viewing area and hiked a bit of the way in.\n\t\t\t\t\t</p>\n\t\t\t\t\t<div class=\"container\">\n\t\t\t\t\t\t<div class=\"row\">\n\t\t\t\t\t\t\t<div id=\"carousel2\" class=\"carousel slide\" data-ride=\"carousel\">\n\t\t\t\t\t\t\t\t<ol class=\"carousel-indicators\">\n\t\t\t\t\t\t\t\t\t<li data-target=\"#carousel2\" data-slide-to=\"0\" class=\"active\"></li>\n\t\t\t\t\t\t\t\t\t<li data-target=\"#carousel2\" data-slide-to=\"1\"></li>\n\t\t\t\t\t\t\t\t\t<li data-target=\"#carousel2\" data-slide-to=\"2\"></li>\n\t\t\t\t\t\t\t\t</ol>\n\t\t\t\t\t\t\t\t<div class=\"carousel-inner\" role=\"listbox\">\n\t\t\t\t\t\t\t\t\t<div class=\"item active\"><img src=\"img/tourdivide/day33/day33pic08.JPG\" alt=\"First slide image\"\n\t\t\t\t\t\t\t\t\t                              class=\"center-block\">\n\t\t\t\t\t\t\t\t\t\t<div class=\"carousel-caption\">\n\t\t\t\t\t\t\t\t\t\t\t<h3>Hoodoos</h3>\n\t\t\t\t\t\t\t\t\t\t\t<p>1</p>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t<div class=\"item\"><img src=\"img/tourdivide/day33/day33pic09.JPG\" alt=\"Second slide image\"\n\t\t\t\t\t\t\t\t\t                       class=\"center-block\">\n\t\t\t\t\t\t\t\t\t\t<div class=\"carousel-caption\">\n\t\t\t\t\t\t\t\t\t\t\t<h3>La Ventana Natural Arch</h3>\n\t\t\t\t\t\t\t\t\t\t\t<p>2</p>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t<div class=\"item\"><img src=\"img/tourdivide/day33/day33pic10.JPG\" alt=\"Third slide image\"\n\t\t\t\t\t\t\t\t\t                       class=\"center-block\">\n\t\t\t\t\t\t\t\t\t\t<div class=\"carousel-caption\">\n\t\t\t\t\t\t\t\t\t\t\t<h3>Across from the arch</h3>\n\t\t\t\t\t\t\t\t\t\t\t<p>3</p>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t<a class=\"left carousel-control\" href=\"#carousel2\" role=\"button\" data-slide=\"prev\">\n\t\t\t\t\t\t\t\t\t<span class=\"glyphicon glyphicon-chevron-left\" aria-hidden=\"true\"></span>\n\t\t\t\t\t\t\t\t\t<span class=\"sr-only\">Previous</span></a>\n\t\t\t\t\t\t\t\t<a class=\"right carousel-control\" href=\"#carousel2\" role=\"button\" data-slide=\"next\">\n                                        <span class=\"glyphicon glyphicon-chevron-right\" aria-hidden=\"true\">\n                                        </span><span class=\"sr-only\">Next</span>\n\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div><!-- /.row -->\n\t\t\t\t\t</div><!-- /.container -->\n\t\t\t\t\t<h3 class=\"section-heading\">Rolling on toward Quamado</h3>\n\t\t\t\t\t<div class=\"col-sm-12 blog-post\">\n\t\t\t\t\t\t<div class=\"col-sm-6\">\n\t\t\t\t\t\t\t<picture>\n\t\t\t\t\t\t\t\t<img class=\"img-responsive\" src=\"img/tourdivide/day33/day33pic06.JPG\" alt=\"\" width=\"100%\">\n\t\t\t\t\t\t\t\t<span class=\"caption text-muted\">Really a beautiful day</span>\n\t\t\t\t\t\t\t</picture>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"col-sm-6\">\n\t\t\t\t\t\t\t<p>At the end of the Malpais National Monument the TD route turned south toward Pie Town and I continued\n\t\t\t\t\t\t\t\ton NM 117 toward Quamado. I still had 50 miles to go.</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\n\n\t\t\t\t\t<picture>\n\t\t\t\t\t\t<img class=\"img-responsive\" src=\"img/tourdivide/day33/day33pic11.JPG\" alt=\"\" width=\"100%\">\n\t\t\t\t\t\t<span class=\"caption text-muted\">You couldn't really see where these sections would end because you had walls like this on both sides.</span>\n\t\t\t\t\t</picture>\n\t\t\t\t\t<h2 class=\"section-heading\">27 Miles</h2>\n\t\t\t\t\t<div class=\"col-sm-12 blog-post\">\n\t\t\t\t\t\t<div class=\"col-sm-6\">\n\t\t\t\t\t\t\t<picture>\n\t\t\t\t\t\t\t\t<img class=\"img-responsive\" src=\"img/tourdivide/day33/day33pic12.JPG\" alt=\"\" width=\"100%\">\n\t\t\t\t\t\t\t\t<span class=\"caption text-muted\">27 miles to the end of the Malpais byway.\n                                    </span>\n\t\t\t\t\t\t\t</picture>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"col-sm-6\">\n\t\t\t\t\t\t\t<p>The mile post \"27\" was always a good one to see. It meant I had either just covered 27 miles or I had\n\t\t\t\t\t\t\t\t27 miles to the end of a road which was the case on this day. 27 miles was the distance from my office\n\t\t\t\t\t\t\t\tin Manhattan and my home in Ridgewood. I had started occasionally riding to work a few days a week a few\n\t\t\t\t\t\t\t\tyears ago and increased my frequency when I decided to do the Tour Divide.</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<br>\n\t\t\t\t\t<p>During the TD I would always get a mental boost when I would get to the \"27 miles to go\" part of my day\n\t\t\t\t\t\tbecause I could visualize the distance and convince myself that \"all\" I had to do was ride home from\n\t\t\t\t\t\twork.</p>\n\t\t\t\t\t<picture>\n\t\t\t\t\t\t<img class=\"img-responsive\" src=\"img/tourdivide/day33/day33pic13.JPG\" alt=\"\" width=\"95%\">\n\t\t\t\t\t\t<span class=\"caption text-muted\">Flat ground where the lava was able to spread out.\n                            </span>\n\t\t\t\t\t</picture>\n\t\t\t\t\t<picture>\n\t\t\t\t\t\t<img class=\"img-responsive\" src=\"img/tourdivide/day33/day33pic14.JPG\" alt=\"\" width=\"95%\">\n\t\t\t\t\t\t<span class=\"caption text-muted\">The last visible lava on the southern edge of the park</span>\n\t\t\t\t\t</picture>\n\t\t\t\t\t<p>The next 27 miles was a rolling section going south west. There were no big hills to go over just a gradual\n\t\t\t\t\t\tuphill where each successive hill is a bit higher than the last.</p>\n\n\t\t\t\t\t<div class=\"container\">\n\t\t\t\t\t\t<div class=\"row\">\n\t\t\t\t\t\t\t<div id=\"carousel3\" class=\"carousel slide\" data-ride=\"carousel\">\n\t\t\t\t\t\t\t\t<ol class=\"carousel-indicators\">\n\t\t\t\t\t\t\t\t\t<li data-target=\"#carousel3\" data-slide-to=\"0\" class=\"active\"></li>\n\t\t\t\t\t\t\t\t\t<li data-target=\"#carousel3\" data-slide-to=\"1\"></li>\n\t\t\t\t\t\t\t\t\t<li data-target=\"#carousel3\" data-slide-to=\"2\"></li>\n\t\t\t\t\t\t\t\t</ol>\n\t\t\t\t\t\t\t\t<div class=\"carousel-inner\" role=\"listbox\">\n\t\t\t\t\t\t\t\t\t<div class=\"item active\"><img src=\"img/tourdivide/day33/day33pic15.JPG\" alt=\"First slide image\"\n\t\t\t\t\t\t\t\t\t                              class=\"center-block\">\n\t\t\t\t\t\t\t\t\t\t<div class=\"carousel-caption\">\n\t\t\t\t\t\t\t\t\t\t\t<p>1</p>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t<div class=\"item\"><img src=\"img/tourdivide/day33/day33pic16.JPG\" alt=\"Second slide image\"\n\t\t\t\t\t\t\t\t\t                       class=\"center-block\">\n\t\t\t\t\t\t\t\t\t\t<div class=\"carousel-caption\">\n\t\t\t\t\t\t\t\t\t\t\t<p>2</p>\n\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t<div class=\"item\"><img src=\"img/tourdivide/day33/day33pic17.JPG\" alt=\"Third slide image\"\n\t\t\t\t\t\t\t\t\t                       class=\"center-block\">\n\t\t\t\t\t\t\t\t\t\t<div class=\"carousel-caption\">\n\t\t\t\t\t\t\t\t\t\t\t<p>3</p>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t<a class=\"left carousel-control\" href=\"#carousel3\" role=\"button\" data-slide=\"prev\">\n\t\t\t\t\t\t\t\t\t<span class=\"glyphicon glyphicon-chevron-left\" aria-hidden=\"true\"></span>\n\t\t\t\t\t\t\t\t\t<span class=\"sr-only\">Previous</span></a>\n\t\t\t\t\t\t\t\t<a class=\"right carousel-control\" href=\"#carousel3\" role=\"button\" data-slide=\"next\">\n                                        <span class=\"glyphicon glyphicon-chevron-right\" aria-hidden=\"true\">\n                                        </span><span class=\"sr-only\">Next</span>\n\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div><!-- /.row -->\n\t\t\t\t\t</div><!-- /.container -->\n\t\t\t\t\t<h2 class=\"section-heading\">On to Quemado</h2>\n\t\t\t\t\t<p>The final section south from Malpais to Quemado was my first riding experience with the wind switch. I had\n\t\t\t\t\t\tplanned my day to try and get to Quemado by 2pm to avoid the afternoon wind. Unfortunately the wind started\n\t\t\t\t\t\tabout 11:45am. I was still 20 miles from town and it appeared that someone had turned on a fan and started\n\t\t\t\t\t\tblowing it in my face. The last seven miles were downhill so this balanced out the wind and I was able to\n\t\t\t\t\t\tcomplete my day by 2pm.</p>\n\t\t\t\t\t<p>Quemado, NM turned out to be 5 blocks long and 3 blocks wide. On the main street it had more closed\n\t\t\t\t\t\tbuildings than open. I was glad it had an nice convenience store with Wifi and what appeared to be a\n\t\t\t\t\t\treasonably new motel.</p>\n\t\t\t\t\t<picture>\n\t\t\t\t\t\t<img class=\"img-responsive\" src=\"img/tourdivide/day33/day33pic19.JPG\" alt=\"\" width=\"95%\">\n\t\t\t\t\t\t<span class=\"caption text-muted\">Gas station/convenience store, Quemado, NM\n                            </span>\n\t\t\t\t\t</picture>\n\t\t\t\t\t<div class=\"col-sm-12 blog-post\">\n\t\t\t\t\t\t<div class=\"col-sm-6\">\n\t\t\t\t\t\t\t<picture>\n\t\t\t\t\t\t\t\t<img class=\"img-responsive\" src=\"img/tourdivide/day33/day33pic18.JPG\" alt=\"\" width=\"95%\">\n\t\t\t\t\t\t\t\t<span class=\"caption text-muted\">Happy to be under cover for the afternoon.\n                                    </span>\n\t\t\t\t\t\t\t</picture>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"col-sm-6\">\n\t\t\t\t\t\t\t<p>I spent most of the day at the gas station / convenience store which had Wifi and also fruit and\n\t\t\t\t\t\t\t\tfood.</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<p>The Largo Cafe and Motel had absolutely the grumpiest employees I experienced on my ride. The hotel had no\n\t\t\t\t\t\tWifi because \"the owner took the box\". It had a laundry room but \"owner doesn't allow people to use it\"</p>\n\t\t\t\t\t<picture>\n\t\t\t\t\t\t<img class=\"img-responsive\" src=\"img/tourdivide/day33/day33pic20.JPG\" alt=\"\" width=\"95%\">\n\t\t\t\t\t\t<span class=\"caption text-muted\">The Tumbleweed Trading Post had seen better days.\n                            </span>\n\t\t\t\t\t</picture>\n\t\t\t\t\t<picture>\n\t\t\t\t\t\t<img class=\"img-responsive\" src=\"img/tourdivide/day33/day33pic21.JPG\" alt=\"\" width=\"95%\">\n\t\t\t\t\t\t<span class=\"caption text-muted\">The Largo was the last motel standing among about 5.\n                            </span>\n\t\t\t\t\t</picture>\n\t\t\t\t\t<div class=\"col-sm-12 blog-post\">\n\t\t\t\t\t\t<div class=\"col-sm-6\">\n\t\t\t\t\t\t\t<p>After returning from the gas station when I went into my room I found a garden snake slithering across\n\t\t\t\t\t\t\t\tand ultimately under my bed. The staff came in with shovels and brooms and eventually evicted the snake.\n\t\t\t\t\t\t\t\tI got the room next store and ordered take out from the cafe.</p>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"col-sm-6\">\n\t\t\t\t\t\t\t<picture>\n\t\t\t\t\t\t\t\t<img class=\"img-responsive\" src=\"img/tourdivide/day33/day33pic22.JPG\" alt=\"\" width=\"95%\">\n\t\t\t\t\t\t\t\t<span class=\"caption text-muted\">Snake moving on\n                                    </span>\n\t\t\t\t\t\t\t</picture>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t\t<h3 class=\"section-heading\">Sundown over Quamado</h3>\n\t\t\t\t\t<div class=\"container\">\n\t\t\t\t\t\t<div class=\"row\">\n\t\t\t\t\t\t\t<div id=\"carousel4\" class=\"carousel slide\" data-ride=\"carousel\">\n\t\t\t\t\t\t\t\t<ol class=\"carousel-indicators\">\n\t\t\t\t\t\t\t\t\t<li data-target=\"#carousel4\" data-slide-to=\"0\" class=\"active\"></li>\n\t\t\t\t\t\t\t\t\t<li data-target=\"#carousel4\" data-slide-to=\"1\"></li>\n\t\t\t\t\t\t\t\t\t<li data-target=\"#carousel4\" data-slide-to=\"2\"></li>\n\t\t\t\t\t\t\t\t</ol>\n\t\t\t\t\t\t\t\t<div class=\"carousel-inner\" role=\"listbox\">\n\t\t\t\t\t\t\t\t\t<div class=\"item active\"><img src=\"img/tourdivide/day33/day33pic23.JPG\" alt=\"First slide image\"\n\t\t\t\t\t\t\t\t\t                              class=\"center-block\">\n\t\t\t\t\t\t\t\t\t\t<div class=\"carousel-caption\">\n\t\t\t\t\t\t\t\t\t\t\t<h3>Looking out at the afternoon rain in the mountains to the east</h3>\n\t\t\t\t\t\t\t\t\t\t\t<p>1</p>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t<div class=\"item\"><img src=\"img/tourdivide/day33/day33pic24.JPG\" alt=\"Second slide image\"\n\t\t\t\t\t\t\t\t\t                       class=\"center-block\">\n\t\t\t\t\t\t\t\t\t\t<div class=\"carousel-caption\">\n\t\t\t\t\t\t\t\t\t\t\t<h3>The end of the day</h3>\n\t\t\t\t\t\t\t\t\t\t\t<p>2</p>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t<div class=\"item\"><img src=\"img/tourdivide/day33/day33pic25.JPG\" alt=\"Third slide image\"\n\t\t\t\t\t\t\t\t\t                       class=\"center-block\">\n\t\t\t\t\t\t\t\t\t\t<div class=\"carousel-caption\">\n\t\t\t\t\t\t\t\t\t\t\t<h3>Sundown in Quamado</h3>\n\t\t\t\t\t\t\t\t\t\t\t<p>3</p>\n\t\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t\t<a class=\"left carousel-control\" href=\"#carousel4\" role=\"button\" data-slide=\"prev\">\n\t\t\t\t\t\t\t\t\t<span class=\"glyphicon glyphicon-chevron-left\" aria-hidden=\"true\"></span>\n\t\t\t\t\t\t\t\t\t<span class=\"sr-only\">Previous</span></a>\n\t\t\t\t\t\t\t\t<a class=\"right carousel-control\" href=\"#carousel4\" role=\"button\" data-slide=\"next\">\n                                        <span class=\"glyphicon glyphicon-chevron-right\" aria-hidden=\"true\">\n                                        </span><span class=\"sr-only\">Next</span>\n\t\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div><!-- /.row -->\n\t\t\t\t\t</div><!-- /.container -->\n\t\t\t\t\t<p>\n\t\t\t\t\t\tJuly 11 - 85 miles - Grants to Quamato, NM\n\t\t\t\t\t</p>\n\n\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t\t\n\t\t\t\t</div><!-- /.blog-main -->\n\t\t\t</div><!-- /.blog-post -->\n\t\t</div><!-- /.row -->\n\t</div><!-- /.container -->"
